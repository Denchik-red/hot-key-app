// This is Prisma schema file,

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
}

model User {
  id   Int   @id @default(autoincrement())
  name String
  DeathCounter DeathCounter?
}

model DeathCounter {
  userId Int @unique
  user User @relation(fields: [userId], references: [id])
  count  Int @default(0)
}